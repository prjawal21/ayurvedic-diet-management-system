# Server
PORT=5000
NODE_ENV=production

# Database - Get from MongoDB Atlas
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/vedacare?retryWrites=true&w=majority

# Auth
JWT_SECRET=your_jwt_secret_here_minimum_32_characters

# Frontend URL - for CORS (your Vercel URL after deployment)
FRONTEND_URL=https://your-app.vercel.app

# Groq AI (optional - falls back to rule-based if not set)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
